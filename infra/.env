# ==============================================================================
# ENT EST Salé — Infrastructure Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is git-ignored. Never commit real credentials.
# ==============================================================================

# ── Cluster ───────────────────────────────────────────────────────────────────
MODE=kind                          # kind | existing
CLUSTER_NAME=ent-est
KIND_CONFIG=./cluster/kind-config.yaml
KUBE_CONTEXT=                      # only used when MODE=existing

# ── Namespaces ────────────────────────────────────────────────────────────────
PLATFORM_NS=ent-platform
APPS_NS=ent-apps
OBS_NS=ent-observability
TRAEFIK_NS=traefik

# ── Bootstrap behaviour ───────────────────────────────────────────────────────
PERSISTENCE_ENABLED=false          # true → PVCs; false → emptyDir (local dev)
SKIP_WAIT=false                    # true → skip all kubectl rollout status waits
POD_WAIT_TIMEOUT=600s

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_PASSWORD=ChangeMe_123!

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=ent
RABBITMQ_PASSWORD=ChangeMe_123!

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=ChangeMe_123!

# ── Cassandra ─────────────────────────────────────────────────────────────────
# The official Cassandra image always bootstraps with superuser "cassandra".
# CASSANDRA_PASSWORD is the new password applied via postStart lifecycle hook.
CASSANDRA_PASSWORD=ChangeMe_123!
